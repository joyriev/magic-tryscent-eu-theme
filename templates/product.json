            "rating": 5,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_3WY73x": {
          "type": "review",
          "settings": {
            "content": "<p>\"Ich habe vergeblich versucht, Düfte zu finden, die teuer riechen und lange halten. Die Passform ist genau das, wonach ich gesucht habe.\"</p>",
