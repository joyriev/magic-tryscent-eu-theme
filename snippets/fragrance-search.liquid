  // ===== FUZZY MATCH SCORE =====
  function calculateFuzzyScore(query, text) {
    if (!text || !query) return 0;
    
    const q = query.toLowerCase();
    const t = text.toLowerCase();
    
    // Exact match = highest score
    if (t === q) return 100;
    
    // Contains = high score
    if (t.includes(q)) return 90;
    
    // All query chars in order = medium-high score
    let queryIndex = 0;
    for (let i = 0; i < t.length && queryIndex < q.length; i++) {
      if (t[i] === q[queryIndex]) queryIndex++;
    }
    if (queryIndex === q.length) return 70; // All chars found in order
    
    // Partial word match
    const queryWords = q.split(/\s+/);
    const textWords = t.split(/\s+/);
    let matchedWords = 0;
    
    for (const qWord of queryWords) {
      for (const tWord of textWords) {
        if (tWord.includes(qWord) || qWord.includes(tWord)) {
          matchedWords++;
          break;
        }
      }
    }
    
    if (matchedWords > 0) {
      return (matchedWords / queryWords.length) * 60;
    }
    
    return 0;
  }

  // ===== SEARCH IN HARDCODED PRODUCTS WITH FUZZY MATCHING =====
  function searchHardcodedProducts(query) {
    if (!query || query.length < 1) return [];
    
    const queryLower = query.toLowerCase().trim();
    const results = [];
    const addedIds = new Set();
    
    hardcodedProducts.forEach(product => {
      if (addedIds.has(product.id)) return;
      
      let score = 0;
      
      // Check title
      score = Math.max(score, calculateFuzzyScore(queryLower, product.title));
      
      // Check brand
      score = Math.max(score, calculateFuzzyScore(queryLower, product.brand) * 0.9);
      
      // Check search terms
      if (product.searchTerms) {
        for (const term of product.searchTerms) {
          score = Math.max(score, calculateFuzzyScore(queryLower, term) * 0.95);
        }
      }
      
      // Check number
      if (product.number && (product.number === queryLower || product.number.includes(queryLower))) {
        score = Math.max(score, 95);
      }
      
      if (score > 30) { // Lowered threshold to catch more results
        results.push({ product, score });
        addedIds.add(product.id);
      }
    });
    
    results.sort((a, b) => b.score - a.score);
    return results;
  }

  // ===== FIND HARDCODED PRODUCT BY CATALOG PERFUME =====
  function findHardcodedProductByPerfume(perfume) {
    if (!perfume) return null;
    
    console.log('🔍 Zoeken naar bijpassend product voor:', perfume.naam || perfume.name);
    
    // Try to find by product number first
    if (perfume.productnummers && perfume.productnummers.length > 0) {
      for (const num of perfume.productnummers) {
        // Try exact match
        let match = hardcodedProducts.find(p => p.number === num.toString());
        if (match) {
          console.log(`✅ Gevonden op nummer ${num}:`, match.title);
          return match;
        }
        
        // Try with leading zeros
        match = hardcodedProducts.find(p => p.number === num.toString().padStart(3, '0'));
        if (match) {
          console.log(`✅ Gevonden op nummer ${num} (met leading zeros):`, match.title);
          return match;
        }
      }
    }
    
    // Try to find by brand
    const perfumeBrand = (perfume.merk || perfume.brand || '').toLowerCase();
    const matches = hardcodedProducts.filter(p => 
      p.brand.toLowerCase().includes(perfumeBrand) || 
      perfumeBrand.includes(p.brand.toLowerCase())
    );
    
    if (matches.length > 0) {
      console.log(`✅ Gevonden ${matches.length} matches op merk`);
      return matches[0];
    }
    
    console.log('❌ Geen bijpassend product gevonden');
    return null;
  }

  // ===== GET RECOMMENDATIONS - SAME BRAND, SAME GENDER =====
  function getRecommendationsForProduct(product) {
    if (!product) return [];
    
    console.log('🎯 Getting recommendations for:', product.title);
    
    // Get ALL products from SAME BRAND with SAME GENDER
    const recommendations = hardcodedProducts
      .filter(p => 
        p.brandKey === product.brandKey && 
        p.id !== product.id &&
        p.gender === product.gender
      )
      .slice(0, 1); // Take first one
    
    console.log(`💡 Found ${recommendations.length} same-brand, same-gender recommendations`);
    
    return recommendations;
  }

