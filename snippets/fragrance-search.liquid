  // ===== INITIALIZE YOUR SHOPIFY PRODUCTS (FIXED) =====
  function fcInitProducts() {
    fcProducts = (window.hardcodedProducts || hardcodedProducts).map(p => ({
      id: p.id,
      title: p.title,
