    const name = perfume.naam || perfume.name || 'Onbekend Parfum';
    const brand = perfume.merk || perfume.brand || 'Onbekend Merk';
    const year = perfume.jaar || '';
    const gender = perfume.geslacht || '';
    const description = perfume.beschrijving || perfume.description || 'Geen beschrijving beschikbaar.';
    
