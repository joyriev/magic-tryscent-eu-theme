  window.fcGoBack = function() {
    currentView = 'search';
    if (currentSearchQuery.length >= 1) {
      performSearch(currentSearchQuery);
    } else {
      steps.style.display = 'block';
      content.innerHTML = '';
    }
  };

  // ===== SHOW NOTIFICATION =====
  function showNotification(message) {
    let notification = document.querySelector('.fc-notification');
    if (!notification) {
      notification = document.createElement('div');
      notification.className = 'fc-notification';
      document.body.appendChild(notification);
    }
    
    notification.textContent = message;
    notification.classList.add('show');
    
    setTimeout(() => {
      notification.classList.remove('show');
    }, 2000);
  }

  // ===== UPDATE OFFER DISPLAY =====
  function updateOfferDisplay(itemCount) {
    if (!offerStatus || !offerProgress || !offerMessage || !offerSubtext) return;
    
    const percentage = Math.min((itemCount / 3) * 100, 100);
    offerProgress.style.width = percentage + '%';
    
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 GRATIS!';
      offerSubtext.textContent = 'Du qualifizierst dich für ein gratis Geschenk!';
      offerMessage.textContent = '🎉 Du qualifizierst dich für ein GRATIS Geschenk!';
      offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      offerSubtext.textContent = `Füge ${needed} mehr hinzu für ein gratis Geschenk`;
      offerMessage.textContent = `Füge ${needed} mehr Artikel hinzu für ein gratis Geschenk`;
      offerBanner.classList.remove('qualified');
    }
  }

  // ===== FETCH CART AND UPDATE COUNT =====
  window.fetchCartAndUpdate = function() {
    return fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        updateOfferDisplay(cart.item_count);
        return cart;
      })
      .catch(() => ({ item_count: 0 }));
  };

  // ===== ADVANCED TEXT NORMALIZATION =====
  function normalizeText(text) {
    if (!text) return '';
    
    let normalized = text.toLowerCase().trim();
    
    // Remove accents
    const accents = {
      'á': 'a', 'à': 'a', 'â': 'a', 'ã': 'a', 'ä': 'a', 'å': 'a', 'ā': 'a',
      'é': 'e', 'è': 'e', 'ê': 'e', 'ë': 'e', 'ē': 'e',
      'í': 'i', 'ì': 'i', 'î': 'i', 'ï': 'i', 'ī': 'i',
      'ó': 'o', 'ò': 'o', 'ô': 'o', 'õ': 'o', 'ö': 'o', 'ō': 'o',
      'ú': 'u', 'ù': 'u', 'û': 'u', 'ü': 'u', 'ū': 'u',
      'ç': 'c', 'ć': 'c', 'š': 's', 'ś': 's', 'ź': 'z', 'ż': 'z',
      'ñ': 'n', 'ń': 'n'
    };
    
    for (const [accented, base] of Object.entries(accents)) {
      normalized = normalized.split(accented).join(base);
    }
    
    // Remove special characters except spaces
    normalized = normalized.replace(/[^a-z0-9\s]/g, '');
    
    return normalized;
  }

  // ===== LEVENSHTEIN DISTANCE (EDIT DISTANCE) =====
  function getLevenshteinDistance(a, b) {
    const aLen = a.length;
    const bLen = b.length;
    
    if (aLen === 0) return bLen;
    if (bLen === 0) return aLen;
    
    const matrix = Array(bLen + 1).fill(null).map(() => Array(aLen + 1).fill(0));
    
    for (let i = 0; i <= aLen; i++) matrix[0][i] = i;
    for (let j = 0; j <= bLen; j++) matrix[j][0] = j;
    
    for (let j = 1; j <= bLen; j++) {
      for (let i = 1; i <= aLen; i++) {
        const indicator = a[i - 1] === b[j - 1] ? 0 : 1;
        matrix[j][i] = Math.min(
          matrix[j][i - 1] + 1,     // deletion
          matrix[j - 1][i] + 1,     // insertion
          matrix[j - 1][i - 1] + indicator  // substitution
        );
      }
    }
    
    return matrix[bLen][aLen];
  }

  // ===== TYPO TOLERANCE SCORING =====
  function getTypoTolerantScore(query, text, maxDistance = 2) {
    const queryNorm = normalizeText(query);
    const textNorm = normalizeText(text);
    
    if (!queryNorm || !textNorm) return 0;
    
    // Exact match after normalization
    if (textNorm === queryNorm) return 100;
    if (textNorm.includes(queryNorm)) return 95;
    
    // Check edit distance
    const distance = getLevenshteinDistance(queryNorm, textNorm);
    const maxLen = Math.max(queryNorm.length, textNorm.length);
    
    if (distance <= maxDistance) {
      return Math.max(0, 100 - (distance * 15));
    }
    
    // Check if query is substring with typos
    if (queryNorm.length >= 3) {
      for (let i = 0; i <= textNorm.length - queryNorm.length; i++) {
        const substring = textNorm.substring(i, i + queryNorm.length);
        const subDistance = getLevenshteinDistance(queryNorm, substring);
        if (subDistance <= maxDistance) {
          return Math.max(0, 80 - (subDistance * 10));
        }
      }
    }
    
    return 0;
  }

  // ===== SPACE-LESS SEARCH (e.g., "diorrose" -> "dior rose") =====
  function getSpaceLessScore(query, text) {
    const queryNorm = normalizeText(query).replace(/\s+/g, '');
    const textNorm = normalizeText(text).replace(/\s+/g, '');
    
    if (!queryNorm || !textNorm) return 0;
    
    if (textNorm === queryNorm) return 100;
    if (textNorm.includes(queryNorm)) return 90;
    if (queryNorm.includes(textNorm)) return 85;
    
    // Edit distance for space-less
    const distance = getLevenshteinDistance(queryNorm, textNorm);
    if (distance <= 3) {
      return Math.max(0, 80 - (distance * 10));
    }
    
    return 0;
  }

  // ===== WORD-BY-WORD SEARCH =====
  function getWordScore(query, text) {
    const queryNorm = normalizeText(query);
    const textNorm = normalizeText(text);
    
    const queryWords = queryNorm.split(/\s+/).filter(w => w.length > 0);
    const textWords = textNorm.split(/\s+/).filter(w => w.length > 0);
    
    if (queryWords.length === 0 || textWords.length === 0) return 0;
    
    let matchedWords = 0;
    
    for (const qWord of queryWords) {
      for (const tWord of textWords) {
        // Exact word match
        if (qWord === tWord) {
          matchedWords++;
          break;
        }
        // Word contains query word
        else if (tWord.includes(qWord) && qWord.length >= 2) {
          matchedWords += 0.8;
          break;
        }
        // Typo tolerance per word
        else {
          const wordDistance = getLevenshteinDistance(qWord, tWord);
          if (wordDistance <= 2 && Math.max(qWord.length, tWord.length) >= 3) {
            matchedWords += 0.6;
            break;
          }
        }
      }
    }
    
    return (matchedWords / queryWords.length) * 100;
  }

  // ===== COMBINED COMPREHENSIVE SEARCH SCORE =====
  function getComprehensiveScore(query, text) {
    if (!query || !text) return 0;
    
    const scores = {
      exact: getTypoTolerantScore(query, text, 0),           // Exact/minimal typos
      typoTolerant: getTypoTolerantScore(query, text, 2),    // 1-2 typos allowed
      spaceLess: getSpaceLessScore(query, text),             // No spaces needed
      wordBased: getWordScore(query, text)                   // Word by word
    };
    
    // Return the best score from all strategies
    return Math.max(scores.exact, scores.typoTolerant, scores.spaceLess, scores.wordBased);
  }

  // ===== PERFORM COMPREHENSIVE SEARCH =====
  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Suche läuft...</div>';
    steps.style.display = 'none';
    
    setTimeout(() => {
      const catalogResults = [];
      const hardcodedResults = [];
      
      // ===== SEARCH IN CATALOG PERFUMES =====
      allPerfumes.forEach(perfume => {
        const perfumeName = perfume.naam || perfume.name || '';
        const perfumeBrand = perfume.merk || perfume.brand || '';
        
        const nameScore = getComprehensiveScore(query, perfumeName);
        const brandScore = getComprehensiveScore(query, perfumeBrand);
        const maxScore = Math.max(nameScore, brandScore);
        
        if (maxScore >= 50) {
          catalogResults.push({
            perfume,
            score: maxScore,
            matchType: nameScore > brandScore ? 'name' : 'brand'
          });
        }
      });
      
      // Sort catalog by score
      catalogResults.sort((a, b) => b.score - a.score);
      
      // ===== SEARCH IN HARDCODED PRODUCTS =====
      hardcodedProducts.forEach(product => {
        const titleScore = getComprehensiveScore(query, product.title);
        const brandScore = getComprehensiveScore(query, product.brand);
        const maxScore = Math.max(titleScore, brandScore);
        
        // Also check search terms
        let termsScore = 0;
        if (product.searchTerms && Array.isArray(product.searchTerms)) {
          for (const term of product.searchTerms) {
            termsScore = Math.max(termsScore, getComprehensiveScore(query, term));
          }
        }
        
        const finalScore = Math.max(maxScore, termsScore);
        
        if (finalScore >= 50) {
          hardcodedResults.push({
            product,
            score: finalScore
          });
        }
      });
      
      // Sort hardcoded by score
      hardcodedResults.sort((a, b) => b.score - a.score);
      
      let html = '';
      
      // ===== DISPLAY CATALOG RESULTS =====
      if (catalogResults.length > 0) {
        html += renderCatalogPerfumes(catalogResults.map(r => r.perfume), query);
      }
      
      // ===== DISPLAY HARDCODED RESULTS =====
      if (hardcodedResults.length > 0) {
        html += `<div class="fc-section-title">🛍️ Unsere Kollektion</div>`;
        
        hardcodedResults.slice(0, 12).forEach(match => {
          const p = match.product;
          const priceFormatted = '€' + (p.price / 100).toFixed(2).replace('.', ',');
          
          html += `
            <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
              <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy">
              <div class="fc-real-perfume-info">
                <div class="fc-real-perfume-name">${p.title}</div>
                <div class="fc-real-perfume-year">${priceFormatted}</div>
              </div>
            </div>
          `;
        });
      }
      
      // ===== NO RESULTS - SHOW SUGGESTIONS =====
      if (catalogResults.length === 0 && hardcodedResults.length === 0) {
        html = '<div class="fc-no-results">Keine Produkte gefunden für "' + query + '"</div>';
        html += renderSuggestions();
      }
      
      content.innerHTML = html;
    }, 300);
  }

  // ===== SEARCH HANDLER =====
  function fcHandleSearch() {
    const query = searchInput.value.trim();
    
    if (query.length < 1) {
      if (currentView !== 'detail') {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
      return;
    }
    
    steps.style.display = 'none';
    currentView = 'search';
    
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }

  // ===== INITIALIZE =====
  document.addEventListener('DOMContentLoaded', function() {
    fcInitProducts(); // Initialize products with global hardcodedProducts
    combineCatalogs();
    
    // Debug: Show what's available
    console.log('📊 Katalog Status:');
    console.log('- window.NederlandseParfumCatalogus:', window.NederlandseParfumCatalogus ? '✓ Geladen' : '✗ Nicht gefunden');
    console.log('- Parfums insgesamt:', allPerfumes.length);
    console.log('- Hardcoded Produkte:', hardcodedProducts.length);
    
    if (searchInput) {
      searchInput.addEventListener('keyup', fcHandleSearch);
    }
    
    if (clearSearch) {
      clearSearch.addEventListener('click', function() {
        searchInput.value = '';
        searchInput.focus();
        steps.style.display = 'block';
        content.innerHTML = '';
        currentView = 'search';
      });
    }
    
    setTimeout(fetchCartAndUpdate, 500);
    
    // Close popup when clicking outside
    document.addEventListener('click', function(event) {
      const searchPopup = document.getElementById('fcSearchPopup');
      const stickyButton = document.getElementById('fcStickyButton');
      
      // Don't close if clicking inside the popup
      if (searchPopup && searchPopup.contains(event.target)) {
        return;
      }
      
      // Don't close if clicking the toggle button
      if (stickyButton && stickyButton.contains(event.target)) {
        return;
      }
      
      // Don't close if clicking on any result item
      if (event.target.closest('.fc-real-perfume-item')) {
        return;
      }
      
      // Don't close if clicking on any product card
      if (event.target.closest('.fc-product-card')) {
        return;
      }
      
      // Don't close if clicking on any button inside popup
      if (event.target.closest('.fc-add-to-cart') || event.target.closest('.fc-view-link') || event.target.closest('.fc-back-btn')) {
        return;
      }
      
      // Only close if clicking outside all these elements and popup is active
      if (searchPopup && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });

    // Escape key handler
    document.addEventListener('keydown', function(e) {
      const searchPopup = document.getElementById('fcSearchPopup');
      if (e.key === 'Escape' && searchPopup && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    console.log('✓ Fragrance Search initialisiert');
  });
})();
</script>