{% doc %}
  @prompt
    I need you to create a home page image type of banner with a full-screen image based on the image that is going to be inputted, and the sizing has to be dynamic based on desktop and mobile. Desktop: 2048 x 1024
    Mobile: 1200 x 1600
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullscreen-banner-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .ai-fullscreen-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-fullscreen-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-fullscreen-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
  }

  .ai-fullscreen-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 24px;
    font-size: 16px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-fullscreen-banner-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}vh;
    }
  }
{% endstyle %}

<fullscreen-banner-{{ ai_gen_id }}
  class="ai-fullscreen-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.desktop_image and block.settings.mobile_image %}
    <picture>
      <source
        media="(max-width: 749px)"
        srcset="{{ block.settings.mobile_image | image_url: width: 1200 }}"
      >
      <source
        media="(min-width: 750px)"
        srcset="{{ block.settings.desktop_image | image_url: width: 2048 }}"
      >
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2048 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        class="ai-fullscreen-banner-image-{{ ai_gen_id }}"
        loading="eager"
        width="{{ block.settings.desktop_image.width }}"
        height="{{ block.settings.desktop_image.height }}"
      >
    </picture>
  {% elsif block.settings.desktop_image %}
    <img
      src="{{ block.settings.desktop_image | image_url: width: 2048 }}"
      alt="{{ block.settings.desktop_image.alt | escape }}"
      class="ai-fullscreen-banner-image-{{ ai_gen_id }}"
      loading="eager"
      width="{{ block.settings.desktop_image.width }}"
      height="{{ block.settings.desktop_image.height }}"
    >
  {% elsif block.settings.mobile_image %}
    <img
      src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
      alt="{{ block.settings.mobile_image.alt | escape }}"
      class="ai-fullscreen-banner-image-{{ ai_gen_id }}"
      loading="eager"
      width="{{ block.settings.mobile_image.width }}"
      height="{{ block.settings.mobile_image.height }}"
    >
  {% else %}
    <div class="ai-fullscreen-banner-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
      <div class="ai-fullscreen-banner-empty-state-{{ ai_gen_id }}">
        Add your desktop and mobile images
      </div>
    </div>
  {% endif %}
</fullscreen-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class FullscreenBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustHeight();
        window.addEventListener('resize', () => this.adjustHeight());
      }

      adjustHeight() {
        const vh = window.innerHeight * 0.01;
        this.style.setProperty('--vh', `${vh}px`);
      }
    }

    customElements.define('fullscreen-banner-{{ ai_gen_id }}', FullscreenBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Fullscreen image banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: 2048 x 1024 pixels"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: 1200 x 1600 pixels"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Mobile height",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Fullscreen image banner"
    }
  ]
}
{% endschema %}
