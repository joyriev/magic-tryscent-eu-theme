{% doc %}
  @prompt
    I need you to create a home page image type of banner with a full-screen image based on the image that is going to be inputted, and the sizing has to be dynamic based on desktop and mobile. Desktop: 2048 x 1024
    Mobile: 1200 x 1600, Not this much of a full screen. It needs to be tailored to the size of the banner that I previously set up. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-banner-container-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-banner-container-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    padding-top: 50%;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 24px;
    font-size: 16px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-container-{{ ai_gen_id }}::before {
      padding-top: 133.33%;
    }
  }
{% endstyle %}

<image-banner-{{ ai_gen_id }}
  class="ai-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-banner-container-{{ ai_gen_id }}">
    {% if block.settings.desktop_image and block.settings.mobile_image %}
      <picture>
        <source
          media="(max-width: 749px)"
          srcset="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        >
        <source
          media="(min-width: 750px)"
          srcset="{{ block.settings.desktop_image | image_url: width: 2048 }}"
        >
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2048 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          class="ai-banner-image-{{ ai_gen_id }}"
          loading="eager"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
        >
      </picture>
    {% elsif block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2048 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        class="ai-banner-image-{{ ai_gen_id }}"
        loading="eager"
        width="{{ block.settings.desktop_image.width }}"
        height="{{ block.settings.desktop_image.height }}"
      >
    {% elsif block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        class="ai-banner-image-{{ ai_gen_id }}"
        loading="eager"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
      >
    {% else %}
      <div class="ai-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-banner-empty-state-{{ ai_gen_id }}">
          Add your desktop and mobile images
        </div>
      </div>
    {% endif %}
  </div>
</image-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('image-banner-{{ ai_gen_id }}', ImageBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: 2048 x 1024 pixels (2:1 ratio)"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: 1200 x 1600 pixels (3:4 ratio)"
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}
