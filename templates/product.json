    "massive_review_hBB37C": {
      "type": "massive-review",
      "blocks": {
        "review_FnY9VG": {
          "type": "review",
          "settings": {
            "content": "<p>\"Dies ist mein erster Einkauf und ich bin begeistert. Ich werde nie wieder woanders Parfüm kaufen. Ich konnte nie einen Duft-Dupe finden, der wirklich authentisch und konsistent roch.\"</p>",
